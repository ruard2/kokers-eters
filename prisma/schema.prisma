generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ParticipationMode {
  EAT
  HOST
  BOTH
}

enum Frequency {
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

enum CommunityScope {
  COMMUNITY_WIDE
  GUESTS_AND_NEWCOMERS
  BOTH
}

enum GatheringType {
  MEAL
  COFFEE_TEA
  BOTH
}

enum RoundStatus {
  DRAFT
  HOST_MAILS_SENT
  COMPLETE
}

enum MatchStatus {
  DRAFT
  HOST_INVITED
  HOST_RESPONDED
  EATER_INVITED
  EATER_CONFIRMED
  FALLBACK_SENT
  CANCELLED
}

model Participant {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  whatsapp         String
  mode             ParticipationMode @default(BOTH)
  comingWithCount  Int               @default(1)
  hostCapacity     Int?
  eaterFrequency   Frequency?
  hostFrequency    Frequency?
  allergies        String?
  address          String?
  cannotEatDays    String?
  cannotHostDays   String?
  adminNoMatch      String?
  isGuest           Boolean           @default(false)
  communityScope   CommunityScope    @default(COMMUNITY_WIDE)
  gatheringType    GatheringType     @default(BOTH)
  cookingPlan      String?
  active           Boolean           @default(true)
  preferenceToken  String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  hostedMatches MealMatch[]  @relation("HostMatches")
  eatenMatches  MealMatch[]  @relation("EaterMatches")
  optOuts       RoundOptOut[]
  emailLogs     EmailLog[]
}

model MatchRound {
  id        String      @id @default(cuid())
  month     DateTime    @unique
  status    RoundStatus @default(DRAFT)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  matches MealMatch[]
}

model PlanningSettings {
  id                   String   @id @default("default")
  horizonMonths        Int      @default(1)
  adminCheckDaysBefore Int      @default(14)
  hostMailDaysBefore   Int      @default(21)
  eaterMailDelayDays   Int      @default(3)
  reminderDaysAfter    Int      @default(3)
  renewalCadence       String   @default("YEAR")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MealMatch {
  id              String      @id @default(cuid())
  roundId         String
  hostId          String
  eaterId         String
  partySize       Int
  hostToken       String      @unique
  eaterToken      String      @unique
  status          MatchStatus @default(DRAFT)
  proposedDates   Json?
  chosenDate      DateTime?
  hostNote        String?
  hostInvitedAt   DateTime?
  hostRespondedAt DateTime?
  eaterInvitedAt  DateTime?
  eaterRespondedAt DateTime?
  fallbackSentAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  round MatchRound  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  host  Participant @relation("HostMatches", fields: [hostId], references: [id], onDelete: Cascade)
  eater Participant @relation("EaterMatches", fields: [eaterId], references: [id], onDelete: Cascade)
  emailLogs EmailLog[]

  @@unique([roundId, hostId, eaterId])
  @@index([roundId])
  @@index([hostId])
  @@index([eaterId])
  @@index([status])
}

model MailTemplate {
  id        String   @id @default(cuid())
  type      String   @unique
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoundOptOut {
  id            String      @id @default(cuid())
  participantId String
  month         DateTime
  createdAt     DateTime    @default(now())

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, month])
  @@index([month])
}

model EmailLog {
  id            String   @id @default(cuid())
  participantId String?
  matchId       String?
  type          String
  contextKey    String?
  toEmail       String
  subject       String
  status        String
  providerId    String?
  error         String?
  createdAt     DateTime @default(now())

  participant Participant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  match       MealMatch?   @relation(fields: [matchId], references: [id], onDelete: SetNull)

  @@index([participantId])
  @@index([matchId])
  @@index([contextKey])
}
